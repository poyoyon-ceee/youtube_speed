{
  "manifest_version": 3,
  "name": "youtube_speed",
  "version": "1.0.0",
  "description": "YouTubeの再生速度をクイックに変更する拡張機能",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"]
    }
  ],
  "action": {
    "default_popup": "index.html"
  }
}
