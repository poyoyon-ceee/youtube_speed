{
  "manifest_version": 3,
  "name": "youtube_speed",
  "version": "1.0.0",
  "description": "YouTubeの再生速度をクイックに変更する拡張機能",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": [
        "src/core/event-bus.js",
        "src/core/state-manager.js",
        "src/utils/config.js",
        "src/content.js"
      ],
      "css": ["src/content.css"]
    }
  ],
  "action": {
    "default_popup": "index.html"
  }
}
